{
    "name": "predatorstudio/laravel-attribute-code-generators",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Predator Studio"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0",
        "illuminate/filesystem": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\LaravelAttributeCodeGenerators\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\LaravelAttributeCodeGenerators\\Providers\\LaravelAttributeCodeGeneratorsProvider"
            ]
        }
    }
}
